{
  "$schema": "https://anthropic.com/claude-code/marketplace.schema.json",
  "name": "w3geekery-lsps",
  "version": "1.0.0",
  "description": "LSP servers for SCSS/CSS/Sass and YAML — for use with the Claude Code LSP tool. (Angular template support documented separately via vscode-mcp; see README.)",
  "owner": {
    "name": "w3geekery"
  },
  "plugins": [
    {
      "name": "lsp-servers",
      "version": "1.0.0",
      "source": "./lsp-servers",
      "description": "SCSS/CSS/Sass and YAML language servers for Claude Code.",
      "category": "development",
      "tags": ["lsp", "scss", "sass", "yaml"],
      "author": {
        "name": "w3geekery"
      },
      "lspServers": {
        "sass": {
          "command": "some-sass-language-server",
          "args": ["--stdio"],
          "transport": "stdio",
          "extensionToLanguage": {
            ".scss": "scss",
            ".sass": "sass",
            ".css": "css"
          },
          "initializationOptions": {},
          "settings": {},
          "maxRestarts": 3
        },
        "yaml": {
          "command": "yaml-language-server",
          "args": ["--stdio"],
          "transport": "stdio",
          "extensionToLanguage": {
            ".yaml": "yaml",
            ".yml": "yaml"
          },
          "initializationOptions": {},
          "settings": {},
          "maxRestarts": 3
        }
      }
    }
  ]
}
