{
  "$schema": "https://anthropic.com/claude-code/marketplace.schema.json",
  "name": "w3geekery-lsps",
  "version": "1.0.0",
  "description": "LSP servers for SCSS/CSS/Sass, Angular templates, and YAML — for use with the Claude Code LSP tool.",
  "owner": {
    "name": "w3geekery"
  },
  "plugins": [
    {
      "name": "lsp-servers",
      "version": "1.0.0",
      "source": "./lsp-servers",
      "description": "SCSS/CSS/Sass, Angular templates, YAML language servers for Claude Code.",
      "category": "development",
      "tags": ["lsp", "scss", "sass", "angular", "yaml"],
      "author": {
        "name": "w3geekery"
      },
      "lspServers": {
        "sass": {
          "command": "some-sass-language-server",
          "args": ["--stdio"],
          "transport": "stdio",
          "extensionToLanguage": {
            ".scss": "scss",
            ".sass": "sass",
            ".css": "css"
          },
          "initializationOptions": {},
          "settings": {},
          "maxRestarts": 3
        },
        "yaml": {
          "command": "yaml-language-server",
          "args": ["--stdio"],
          "transport": "stdio",
          "extensionToLanguage": {
            ".yaml": "yaml",
            ".yml": "yaml"
          },
          "initializationOptions": {},
          "settings": {},
          "maxRestarts": 3
        },
        "angular": {
          "command": "ngserver",
          "args": [
            "--stdio",
            "--tsProbeLocations",
            "/Users/cstacer/Projects/zb/ui/node_modules",
            "--ngProbeLocations",
            "/Users/cstacer/Projects/zb/ui/node_modules"
          ],
          "transport": "stdio",
          "extensionToLanguage": {
            ".html": "html"
          },
          "initializationOptions": {},
          "settings": {},
          "startupTimeout": 120000,
          "maxRestarts": 3
        }
      }
    }
  ]
}
